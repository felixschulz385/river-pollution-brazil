{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Health Mortality Fetch",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/code/data/cli.py",
            "args": [
                "health",
                "fetch",
                "--subtype",
                "mortality"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Health Birth Fetch",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/code/data/cli.py",
            "args": [
                "health",
                "fetch",
                "--subtype",
                "birth"
            ],
            "console": "integratedTerminal"
        }
    ]
}