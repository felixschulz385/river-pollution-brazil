{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Health Mortality Fetch",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/code/data/cli.py",
            "args": [
                "health",
                "fetch",
                "--subtype",
                "mortality"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Health Birth Fetch",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/code/data/cli.py",
            "args": [
                "health",
                "fetch",
                "--subtype",
                "birth"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Land Cover Preprocess",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/code/data/cli.py",
            "args": [
                "land-cover",
                "preprocess",
                "--n_jobs",
                "2",
                "--output",
                "test_land_cover.feather"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug River Network - Reachability (Debug Mode)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/code/data/cli.py",
            "args": [
                "river-network",
                "debug",
                "--shapefile-path",
                "${workspaceFolder}/data/river_network/shapefile.parquet",
                "--topology-path",
                "${workspaceFolder}/data/river_network/topology.parquet",
                "--distance-path",
                "${workspaceFolder}/data/river_network/distance_from_estuary.parquet",
                "--output-dir",
                "${workspaceFolder}/data/river_network/debug_output/"
            ],
            "console": "integratedTerminal"
        },
    ]
}